{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tategoto",
  "version": "0.1.0",
  "identifier": "tech.s2n.tategoto",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tategoto",
        "width": 420,
        "height": 620,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
