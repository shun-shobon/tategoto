{
  "name": "tategoto",
  "version": "0.1.0",
  "private": true,
  "description": "MacOS menu bar transcription app that saves microphone transcripts locally.",
  "license": "MIT",
  "author": "NISHIZAWA Shuntaro <me@s2n.tech>",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite --host 127.0.0.1",
